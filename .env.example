# App
NODE_ENV=development
PORT=3000
WS_PORT=3001

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public

# JWT (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# OTP
OTP_TTL_MINUTES=10

# Mail (choose one provider: smtp, firebase, console)
MAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Alanya <no-reply@alanya.app>"

# Firebase (for push notifications + email via Firebase)
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=
FIREBASE_MAIL_COLLECTION=mail

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Media Storage (local or b2)
MEDIA_STORAGE_DIR=./storage/media
MEDIA_MAX_SIZE_MB=50
MEDIA_STORAGE_PROVIDER=local
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_BUCKET=alanya
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_KEY_PREFIX=media/
B2_PRESIGN_EXPIRES_IN_SEC=3600

# WebRTC (STUN/TURN)
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun.cloudflare.com:3478
METERED_API_KEY=
METERED_DOMAIN=
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# Push
PUSH_ENABLED=false
